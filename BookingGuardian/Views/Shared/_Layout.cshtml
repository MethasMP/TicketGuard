@using System.Security.Claims
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketGuard | BusOnlineTicket</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="~/TicketGuard.png" asp-append-version="true" />
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM" crossorigin="anonymous">
    <script src="https://unpkg.com/lucide@0.320.0/dist/umd/lucide.min.js"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="brand-logo">
                <img src="~/TicketGuard.png" asp-append-version="true" alt="TicketGuard logo" class="brand-logo-img" />
            </div>
            <span class="brand-name">TicketGuard</span>
        </div>

        <nav class="nav-sidebar">
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" href="/">
                <i data-lucide="layout-dashboard"></i>
                Dashboard
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Health" ? "active" : "")" href="/health/history">
                <i data-lucide="activity"></i>
                System Status
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reports" ? "active" : "")" href="/reports">
                <i data-lucide="bar-chart-2"></i>
                Reports
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Audit" ? "active" : "")" href="/audit">
                <i data-lucide="scroll-text"></i>
                Audit Logs
            </a>
        </nav>

        <div style="padding: 1.5rem; border-top: 1px solid rgba(255, 255, 255, 0.05);">
            <form asp-controller="Account" asp-action="Logout" method="get">
                <button type="submit" class="nav-link logout-btn" style="background:none; border:none; width: 100%; text-align: left; color: #a1a1aa;">
                    <i data-lucide="log-out"></i>
                    Sign Out
                </button>
            </form>
        </div>
    </aside>

    <div class="main-wrapper">
        <main class="app-content reveal">
            @RenderBody()
        </main>
    </div>

    <!-- Focus Overlay -->
    <div id="focusOverlay" class="resolution-focus-overlay">
        <div class="focus-card" id="focusCardContent"></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" crossorigin="anonymous"></script>
    <script>
        // Global Fetch interceptor for Anti-Forgery Token
        const originalFetch = window.fetch;
        window.fetch = function() {
            let [resource, config] = arguments;
            if (config && ['POST', 'PUT', 'DELETE'].includes(config.method?.toUpperCase())) {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if (token) {
                    config.headers = {
                        ...config.headers,
                        'RequestVerificationToken': token
                    };
                }
            }
            return originalFetch(resource, config);
        };

        lucide.createIcons();

        function showFocus(contentHtml) {
            const overlay = document.getElementById('focusOverlay');
            const card = document.getElementById('focusCardContent');
            card.innerHTML = contentHtml;
            overlay.classList.add('visible');
            lucide.createIcons();
        }

        function hideFocus() {
            document.getElementById('focusOverlay').classList.remove('visible');
        }

        document.getElementById('focusOverlay')?.addEventListener('click', (e) => {
            if (e.target === document.getElementById('focusOverlay')) hideFocus();
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
