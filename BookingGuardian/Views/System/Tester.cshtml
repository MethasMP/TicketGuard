@{
    ViewData["Title"] = "Guardian Pulse Tester";
}

<div class="app-container p-4">
    <div class="mb-5">
        <h1 class="title-main mb-1">Simulator Lab</h1>
        <p class="text-secondary small font-mono">Guardian Integrity & Pulse Verification System</p>
    </div>

    <div class="row g-5">
        <!-- Input Panel -->
        <div class="col-md-5">
            <div class="glass-card mb-4 border-primary border-opacity-10">
                <h3 class="h6 fw-800 text-primary-emphasis mb-4 text-uppercase tracking-widest">Scenario Builder</h3>
                
                <div class="mb-3">
                    <label class="tactile-label">Destination Route</label>
                    <input type="text" id="testRoute" class="form-control bg-dark border-light border-opacity-10 text-white rounded-4 px-3 py-2 font-mono" value="MARS-VALLEY-EXPRESS">
                </div>

                <div class="mb-3">
                    <label class="tactile-label">Transaction Amount (THB)</label>
                    <input type="number" id="testAmount" class="form-control bg-dark border-light border-opacity-10 text-white rounded-4 px-3 py-2 font-mono" value="5000">
                </div>

                <div class="mb-3">
                    <label class="tactile-label">Passenger Legal Name</label>
                    <input type="text" id="testName" class="form-control bg-dark border-light border-opacity-10 text-white rounded-4 px-3 py-2 font-mono" value="CLAUDE OPUS">
                </div>

                <div class="mb-4">
                    <label class="tactile-label">Passenger Contact Email</label>
                    <input type="email" id="testEmail" class="form-control bg-dark border-light border-opacity-10 text-white rounded-4 px-3 py-2 font-mono" value="test@guardian.lab">
                </div>

                <button onclick="runScenario()" id="runBtn" class="btn btn-primary w-100 py-3 fw-800 rounded-pill shadow-lg transition-all animate-pulse">
                    INJECT PAYLOAD & START TEST
                </button>
            </div>

            <div class="glass-card border-danger border-opacity-10">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="h6 fw-800 text-danger mb-0 text-uppercase tracking-widest">Chaos Controls</h3>
                    <span id="chaosStatus" class="badge bg-success x-small px-2">SYSTEM_UP</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="text-secondary small">Simulate API Outage</span>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="outageToggle" onchange="toggleChaos()">
                    </div>
                </div>
                <p class="x-small text-secondary mb-0">Toggle this to simulate Gateway failure. <strong>Current:</strong> <span id="chaosDesc" class="text-success">Normal Operations</span></p>
            </div>

            <!-- Mini User Manual -->
            <div class="mt-4 p-3 rounded-4 border border-light border-opacity-5" style="background: rgba(255,255,255,0.02)">
                <h6 class="x-small fw-800 text-secondary text-uppercase mb-2">Operator Instructions</h6>
                <ul class="list-unstyled x-small text-secondary mb-0" style="line-height: 1.6;">
                    <li>1. Toggle Chaos to simulate a Down state.</li>
                    <li>2. Edit and "Inject" a payload.</li>
                    <li>3. Check Dashboard (Status: Awaiting).</li>
                    <li>4. Toggle Chaos back to Up.</li>
                    <li>5. Click "Trigger Scan" at Dashboard to recover.</li>
                </ul>
            </div>
        </div>

        <!-- Intelligence Output & Interactive Editor -->
        <div class="col-md-7">
            <div class="glass-card h-100 d-flex flex-column" style="min-height: 500px; background: rgba(10,10,10,0.8);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="h6 fw-800 text-secondary mb-0 text-uppercase tracking-widest">Live JSON Payload</h3>
                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 x-small px-3">EDITABLE_MODE</span>
                </div>
                
                <div class="flex-grow-1 position-relative">
                    <textarea id="rawPayload" class="w-100 h-100 font-mono p-4 rounded-4" 
                        style="background: rgba(0,0,0,0.6); color: #00d2ff; font-size: 0.85rem; line-height: 1.6; border: 1px solid rgba(0,210,255,0.1); outline: none; resize: none;"
                        placeholder='{"action": "awaiting_input"}'></textarea>
                </div>

                <div id="statusIndicator" class="mt-2 x-small font-mono text-secondary opacity-50">SYNCED WITH SCENARIO BUILDER v1.0</div>

                <div class="mt-3 pt-3 border-top border-light border-opacity-10 d-flex justify-content-between">
                    <div class="d-flex gap-2">
                        <button onclick="clearTerminal()" class="btn btn-dark btn-sm rounded-pill px-3 x-small border border-light border-opacity-10">RESET</button>
                        <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill px-3 x-small">EXIT_LAB</a>
                    </div>
                    <button onclick="injectRawData()" id="injectRawBtn" class="btn btn-primary btn-sm rounded-pill px-4 fw-800 x-small shadow-lg">
                        <i data-lucide="send" class="me-2" style="width:12px;"></i> INJECT_RAW_POST
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .form-control:focus {
        background: #151515 !important;
        border-color: var(--accent-primary) !important;
        box-shadow: 0 0 10px rgba(0, 114, 255, 0.1);
    }
    .animate-pulse:active {
        transform: scale(0.98);
    }
    .log-entry {
        margin-bottom: 1rem;
        padding-left: 1rem;
        border-left: 2px solid rgba(0, 114, 255, 0.3);
        animation: slideInLeft 0.3s ease-out;
    }
    @@keyframes slideInLeft {
        from { opacity: 0; transform: translateX(-10px); }
        to { opacity: 1; transform: translateX(0); }
    }
</style>

@section Scripts {
    <script>
        const rawArea = document.getElementById('rawPayload');
        const inputs = ['testRoute', 'testAmount', 'testName', 'testEmail'];

        function updateRawFromInputs() {
            const data = {
                route: document.getElementById('testRoute').value,
                amount: parseFloat(document.getElementById('testAmount').value),
                customerName: document.getElementById('testName').value,
                customerEmail: document.getElementById('testEmail').value,
                timestamp: new Date().toISOString(),
                simulatedStatus: "SUCCESS_PENDING"
            };
            rawArea.value = JSON.stringify(data, null, 4);
            document.getElementById('statusIndicator').innerText = "SYNCED WITH BUILDER";
            document.getElementById('statusIndicator').className = "mt-2 x-small font-mono text-info opacity-75";
        }

        rawArea.addEventListener('input', () => {
            document.getElementById('statusIndicator').innerText = "MANUAL_EDIT_MODE (SYNC_PAUSED)";
            document.getElementById('statusIndicator').className = "mt-2 x-small font-mono text-warning opacity-75";
        });

        inputs.forEach(id => {
            document.getElementById(id).addEventListener('input', updateRawFromInputs);
        });

        async function injectRawData() {
            const btn = document.getElementById('injectRawBtn');
            const original = btn.innerHTML;
            
            try {
                let data;
                try {
                    data = JSON.parse(rawArea.value);
                } catch(e) {
                    alert("Invalid JSON format!");
                    return;
                }

                btn.disabled = true;
                btn.innerHTML = "INJECTING...";

                // Map your raw JSON to the API params
                const params = new URLSearchParams({
                    route: data.route || "UNKNOWN",
                    amount: data.amount || 0,
                    name: data.customerName || data.name || "UNNAMED",
                    email: data.customerEmail || data.email || "test@example.com"
                });

                const res = await fetch(`/api/simulator/plant-anomaly?${params.toString()}`, { method: 'POST' });
                const result = await res.json();

                if (res.ok) {
                    alert(`SUCCESS: Booking #${result.reference} planted into system.`);
                    btn.className = "btn btn-success btn-sm rounded-pill px-4 fw-800 x-small shadow-lg animate-pulse";
                    setTimeout(() => {
                        btn.className = "btn btn-primary btn-sm rounded-pill px-4 fw-800 x-small shadow-lg";
                        btn.innerHTML = original;
                        btn.disabled = false;
                    }, 2000);
                }
            } catch (err) {
                alert("Critical Injection Error: " + err.message);
                btn.disabled = false;
                btn.innerHTML = original;
            }
        }

        function clearTerminal() {
            inputs.forEach(id => {
               document.getElementById(id).value = document.getElementById(id).defaultValue;
            });
            updateRawFromInputs();
        }

        async function toggleChaos() {
            const res = await fetch('/api/simulator/toggle-outage', { method: 'POST' });
            const data = await res.json();
            
            const badge = document.getElementById('chaosStatus');
            const desc = document.getElementById('chaosDesc');
            const isUp = data.status === "UP";

            badge.innerText = isUp ? "SYSTEM_UP" : "SYSTEM_DOWN";
            badge.className = `badge ${isUp ? 'bg-success' : 'bg-danger'} x-small px-2`;
            desc.innerText = isUp ? "Normal Operations" : "Service Interruption (Circuit Breaker ON)";
            desc.className = isUp ? "text-success" : "text-danger fw-bold";

            alert(`SABOTAGE_RESULT: ${data.message}`);
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateRawFromInputs();
            lucide.createIcons();
        });
    </script>
}
