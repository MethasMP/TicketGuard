@{
    ViewData["Title"] = "BusOnlineTicket Command Center";
}

<div class="mb-5">
    <div class="d-flex justify-content-between align-items-end border-bottom border-secondary border-opacity-25 pb-3">
        <div>
            <h1 class="title-main">Guardian Mission Control</h1>
            <p class="subtitle-main">Ensuring Safe Passage for Every Journey</p>
        </div>
        <div class="text-end d-flex align-items-center gap-3">
            <span class="text-secondary font-mono small" id="lastUpdatedText">Syncing...</span>
            <button onclick="loadDashboard(true)" class="btn btn-dark btn-sm rounded-pill d-inline-flex align-items-center gap-2 px-3">
                <i data-lucide="refresh-cw" style="width: 14px; height: 14px;"></i>
                Refresh
            </button>
        </div>
    </div>
</div>

<!-- Key Metrics -->
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="guardian-card p-4 info-wrapper">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="p-2 rounded bg-danger bg-opacity-10 text-danger">
                    <i data-lucide="shield-alert"></i>
                </div>
                <span class="text-secondary small fw-600">IMPACT</span>
            </div>
            <div class="display-5 fw-800 mb-1 text-danger" id="openAnomalies">0</div>
            <div class="text-secondary small">Passengers in Limbo</div>
            <div class="info-tooltip" style="bottom: 100%; left: 0; width: 220px; transform: translateY(-10px);">
                จำนวนบุ๊คกิ้งที่ติดปัญหาและผู้โดยสารกำลังรอการแก้ไข (Bookings awaiting resolution)
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="guardian-card p-4 info-wrapper">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="p-2 rounded bg-success bg-opacity-10 text-success">
                    <i data-lucide="ticket"></i>
                </div>
                <span class="text-secondary small fw-600">STABILITY</span>
            </div>
            <div class="display-5 fw-800 mb-1" id="savedBookings">0</div>
            <div class="text-secondary small">Journeys Saved</div>
            <div class="info-tooltip" style="bottom: 100%; left: 0; width: 220px; transform: translateY(-10px);">
                ยอดรวมการจองที่ระบบช่วยกู้คืนสำเร็จ (Successfully secured bookings)
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="guardian-card p-4 info-wrapper">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="p-2 rounded bg-primary bg-opacity-10 text-primary">
                    <i data-lucide="banknote"></i>
                </div>
                <span class="text-secondary small fw-600">RECOVERY</span>
            </div>
            <div class="display-5 fw-800 mb-1" id="recoveredRevenue">฿0</div>
            <div class="text-secondary small">Revenue Saved</div>
            <div class="info-tooltip" style="bottom: 100%; left: 0; width: 220px; transform: translateY(-10px);">
                ยอดเงินรวมทั้งหมดที่กู้คืนกลับมาได้จากการแก้ปัญหา (Total revenue recovered)
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="guardian-card p-4 info-wrapper">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div class="p-2 rounded bg-info bg-opacity-10 text-info">
                    <i data-lucide="zap"></i>
                </div>
                <span class="text-secondary small fw-600">EFFICIENCY</span>
            </div>
            <div class="display-5 fw-800 mb-1" id="guardianAutonomy">0%</div>
            <div class="text-secondary small">Guardian Autonomy</div>
            <div class="info-tooltip" style="bottom: 100%; left: 0; width: 220px; transform: translateY(-10px);">
                อัตราการแก้ไขปัญหาอัตโนมัติโดยไม่ใช้คน (Auto-recovery success rate)
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-5">
    <!-- Main Issue Tracking -->
    <div class="col-lg-8">
        <div class="guardian-card h-100">
            <div class="p-4 border-bottom border-light d-flex justify-content-between align-items-center">
                <h3 class="h6 fw-800 mb-0 d-flex align-items-center gap-2">
                    <i data-lucide="shield-check" class="text-secondary" style="width: 18px;"></i>
                    Active Protection Feed
                    <span id="issuesVisibleCount" class="badge bg-light text-secondary fw-500 ms-2">0 items</span>
                </h3>
                <div class="d-flex gap-2">
                    <div class="dropdown">
                        <button class="btn btn-sm btn-dark border border-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" id="statusFilterBtn">
                            Active Alerts
                        </button>
                        <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end shadow-lg border-secondary" style="z-index: 1050;">
                            <li><a class="dropdown-item" href="#" onclick="filterAnomalies('OPEN', event)">Awaiting Recovery</a></li>
                            <li><a class="dropdown-item" href="#" onclick="filterAnomalies('RESOLVED', event)">Secured Today</a></li>
                            <li><a class="dropdown-item" href="#" onclick="filterAnomalies('IGNORED', event)">Discarded Alerts</a></li>
                            <li><div class="dropdown-divider border-secondary"></div></li>
                            <li><a class="dropdown-item" href="#" onclick="filterAnomalies('ALL', event)">Full History</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            
            <div id="outageFilterBar" class="px-4 py-2 bg-warning bg-opacity-10 border-bottom d-none">
                <div class="d-flex justify-content-between align-items-center">
                    <small class="fw-600 text-warning-emphasis">
                        <i data-lucide="filter" style="width: 12px; margin-right: 4px;"></i>
                        Targeted Outage: <span id="outageFilterName"></span>
                    </small>
                    <button class="btn btn-link btn-sm p-0 text-decoration-none" onclick="clearOutageFilter()">Clear Filter</button>
                </div>
            </div>

            <div class="table-responsive" style="max-height: 520px;">
                <table class="table align-middle mb-0 guardian-table" id="anomaliesTable">
                    <thead class="sticky-top">
                        <tr>
                            <th class="ps-4 py-3 small fw-700 text-uppercase tracking-wider">Reference</th>
                            <th class="py-3 small fw-700 text-uppercase tracking-wider">Route & Entity</th>
                            <th class="py-3 small fw-700 text-uppercase tracking-wider">Impact</th>
                            <th class="py-3 small fw-700 text-uppercase tracking-wider">Detected</th>
                            <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7 text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td colspan="5" class="p-5 text-center">
                                <div class="spinner-border spinner-border-sm text-primary opacity-50 me-2"></div>
                                <span class="text-secondary small">Initializing data layer...</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Partner System Pulse -->
    <div class="col-lg-4">
        <div class="guardian-card h-100">
            <div class="p-4 border-bottom border-light">
                <h3 class="h6 fw-800 mb-0 d-flex align-items-center gap-2">
                    <i data-lucide="activity" class="text-secondary" style="width: 18px;"></i>
                    System Pulse
                </h3>
            </div>
            <div class="p-0">
                <div id="healthList" class="health-pulse-list">
                    <div class="p-5 text-center text-secondary small">
                        Monitoring connections...
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>




@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        let allData = { OPEN: [], RESOLVED: [], IGNORED: [], ALL: [] };
        let currentStatusFilter = 'OPEN';
        let activeOutageFilter = null;

        function setStatusFilterLabel(status) {
            let label = 'Awaiting Recovery';
            if (status === 'ALL') label = 'Full History';
            if (status === 'RESOLVED') label = 'Secured Today';
            if (status === 'IGNORED') label = 'Discarded Alerts';
            document.getElementById('statusFilterBtn').innerText = label;
        }

        function redirectToLoginOnUnauthorized(response) {
            if (response.status !== 401) return false;
            const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
            window.location.href = `/Account/Login?returnUrl=${returnUrl}`;
            return true;
        }

        async function loadDashboard(isManual = false) {
            try {
                // If silent refresh, we don't show the initial loading state
                await Promise.all([
                    loadHealth(isManual),
                    loadSummary(isManual),
                    loadAnomaliesForCurrentContext(isManual)
                ]);
                const el = document.getElementById('lastUpdatedText');
                if (el) {
                    const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                    el.innerText = `Connected • ${time}`;
                    if (isManual) el.classList.add('text-primary'); else el.classList.remove('text-primary');
                }
                lucide.createIcons();
            } catch (err) {
                console.error('Dashboard Load Error:', err);
                if (isManual) {
                    const tbody = document.getElementById('anomaliesTable').querySelector('tbody');
                    tbody.innerHTML = `<tr><td colspan="5" class="p-5 text-center text-danger">Monitoring link severed. Retrying...</td></tr>`;
                }
            }
        }

        async function loadSummary(isManual) {
            const response = await fetch('/api/anomaly/summary');
            if (!response.ok) {
                if (redirectToLoginOnUnauthorized(response)) return;
                return;
            }
            const s = await response.json();
            
            const openEl = document.getElementById('openAnomalies');
            const savedEl = document.getElementById('savedBookings');
            const revenueEl = document.getElementById('recoveredRevenue');
            const autonomyEl = document.getElementById('guardianAutonomy');

            // Subtle value updates
            if (openEl.innerText != (s.openIssues || 0)) openEl.innerText = s.openIssues || 0;
            if (savedEl.innerText != (s.savedBookings || 0)) savedEl.innerText = s.savedBookings || 0;
            
            const revenueText = '฿' + (s.recoveredRevenue || 0).toLocaleString();
            if (revenueEl.innerText != revenueText) revenueEl.innerText = revenueText;
            
            const auto = s.savedBookings > 0 ? Math.round((s.autoRecovered / s.savedBookings) * 100) : 0;
            if (autonomyEl.innerText != (auto + '%')) autonomyEl.innerText = auto + '%';
        }

        async function loadAnomaliesForCurrentContext(isManual) {
            let query = `/api/anomaly?pageSize=200`;
            if (activeOutageFilter) query += `&status=OPEN&outageEndpointHealthId=${activeOutageFilter.id}`;
            else if (currentStatusFilter === 'RESOLVED') query += `&status=RESOLVED&todayOnly=true`;
            else query += `&status=${currentStatusFilter}`;

            const response = await fetch(query);
            if (!response.ok) {
                if (redirectToLoginOnUnauthorized(response)) return;
                return;
            }
            const payload = await response.json();
            const data = payload.data || [];
            
            if (activeOutageFilter) allData.OPEN = data;
            else if (currentStatusFilter === 'OPEN') allData.OPEN = data;
            
            renderAnomalies(data, isManual);
        }

        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return String(unsafe)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        function formatTime(minutes) {
            if (minutes >= 24 * 60) {
                return Math.floor(minutes / (24 * 60)) + 'd ago';
            } else if (minutes >= 60) {
                return Math.floor(minutes / 60) + 'h ago';
            } else {
                return minutes + 'm ago';
            }
        }

        let lastAnomaliesHtml = '';
        function renderAnomalies(data, isManual) {
            const tbody = document.getElementById('anomaliesTable').querySelector('tbody');
            document.getElementById('issuesVisibleCount').innerText = `${data.length} items`;

            if (data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="p-5 text-center text-secondary small">Feed clear. All journeys are safe.</td></tr>`;
                lastAnomaliesHtml = '';
                return;
            }

            const newContent = data.map((item, idx) => {
                const status = (item.status || '').toUpperCase();
                
                // Guardian Status Mapping & Colors
                let statusLabel = status;
                let statusClass = 'bg-secondary-subtle text-secondary';

                if (status === 'OPEN') {
                    statusLabel = 'AWAITING RECOVERY';
                    statusClass = 'bg-danger-subtle text-danger';
                } else if (status === 'RESOLVED') {
                    statusLabel = 'SECURED';
                    statusClass = 'bg-success-subtle text-success';
                } else if (status === 'IGNORED') {
                    statusLabel = 'DISCARDED';
                    statusClass = 'bg-secondary-subtle text-secondary opacity-50';
                }

                let statusBadge = `<span class="badge ${statusClass} rounded-pill px-3 py-2 fw-800" style="font-size: 10px; letter-spacing: 0.5px;">${escapeHtml(statusLabel)}</span>`;
                
                // Only use 'reveal' animation if it's manual refresh or first load
                const animationClass = isManual ? 'reveal' : '';
                const delay = isManual ? `style="--d: ${idx * 0.05}s;"` : '';

                return `
                <tr class="${animationClass}" ${delay} style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <td class="ps-4 fw-800 text-light">#${escapeHtml(item.bookingReference || '---')}</td>
                    <td>
                        <div class="fw-600 small text-light">${escapeHtml(item.route || 'Unknown Route')}</div>
                        <div class="text-secondary" style="font-size: 11px;">${escapeHtml(item.cause || 'Direct Signal')}</div>
                    </td>
                    <td class="fw-700 text-primary">฿${(item.amount || 0).toLocaleString()}</td>
                    <td class="text-secondary small">${escapeHtml(formatTime(item.minutesSinceDetected))}</td>
                    <td class="text-center">${statusBadge}</td>
                </tr>`;
            }).join('');

            // Only update DOM if content actually changed
            if (newContent !== lastAnomaliesHtml) {
                tbody.innerHTML = newContent;
                lastAnomaliesHtml = newContent;
            }
        }

        let lastHealthHtml = '';
        async function loadHealth(isManual) {
            const response = await fetch('/health');
            if (!response.ok) {
                if (redirectToLoginOnUnauthorized(response)) return;
                return;
            }
            const payload = await response.json();
            const endpoints = payload.endpoints || [];
            
            const list = document.getElementById('healthList');
            const newContent = endpoints.map(e => {
                const isDown = e.status === 'DOWN';
                const pulseClass = isDown ? 'pulse-danger' : (e.status === 'UP' ? 'pulse-success' : 'pulse-warning');
                const textClass = isDown ? 'text-danger' : 'text-light';
                
                return `
                <div class="p-4 border-bottom border-light border-opacity-10">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div class="fw-800 ${textClass}">${e.name}</div>
                            <div class="text-secondary small" style="font-size: 11px;">Checked ${new Date(e.checkedAt).toLocaleTimeString()}</div>
                        </div>
                        <div class="status-indicator ${pulseClass}"></div>
                    </div>
                    <div class="d-flex gap-3 small text-secondary">
                        <span class="d-flex align-items-center gap-1"><i data-lucide="clock" style="width:12px;"></i> ${e.responseMs || '?'}ms</span>
                        <span class="d-flex align-items-center gap-1"><i data-lucide="gauge" style="width:12px;"></i> ${Number(e.uptime24h || 0).toFixed(1)}%</span>
                    </div>
                    ${isDown && e.outageAnomalyCount > 0 ? 
                        `<button class="btn btn-link btn-sm p-0 text-danger small mt-2 fw-700" onclick="applyOutageFilter(${e.activeOutageId}, '${(e.name || '').replace(/'/g, "\\'")}')">
                            <i data-lucide="alert-circle" style="width:14px; vertical-align:middle;"></i> View ${e.outageAnomalyCount} impact reports
                        </button>` : ''}
                </div>`;
            }).join('');

            if (newContent !== lastHealthHtml) {
                list.innerHTML = newContent;
                lastHealthHtml = newContent;
            }
        }



        function filterAnomalies(status, e) {
            if (e) e.preventDefault();
            currentStatusFilter = status;
            activeOutageFilter = null;
            document.getElementById('outageFilterBar').classList.add('d-none');
            setStatusFilterLabel(status);
            loadAnomaliesForCurrentContext();
        }

        function applyOutageFilter(id, name) {
            activeOutageFilter = { id, name };
            document.getElementById('outageFilterName').innerText = name;
            document.getElementById('outageFilterBar').classList.remove('d-none');
            loadAnomaliesForCurrentContext();
        }

        function clearOutageFilter() {
            activeOutageFilter = null;
            document.getElementById('outageFilterBar').classList.add('d-none');
            loadAnomaliesForCurrentContext();
        }



        document.addEventListener('DOMContentLoaded', () => {
            loadDashboard();
            setInterval(loadDashboard, 30000);
        });
    </script>
}
