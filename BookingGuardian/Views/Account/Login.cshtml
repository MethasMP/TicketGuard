@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In - TicketGuard | BusOnlineTicket</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="~/TicketGuard.png" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --brand-gradient: linear-gradient(135deg, #1e3a8a 0%, #ca8a04 50%, #ea580c 100%);
            --text-main: #0f172a;
            --text-muted: #64748b;
            --accent: #f97316;
            --input-bg: #f8fafc;
        }
        
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            overflow: hidden;
        }

        .split-container {
            display: flex;
            height: 100vh;
            width: 100vw;
        }

        /* --- Branding Side --- */
        .branding-pane {
            flex: 1.1;
            background: var(--brand-gradient);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 4rem;
            color: white;
            position: relative;
            text-align: center;
        }

        .branding-pane::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
            opacity: 0.05;
            pointer-events: none;
        }

        .logo-box {
            width: 170px;
            height: 170px;
            background: transparent;
            border-radius: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 2rem;
            box-shadow: none;
            padding: 0;
            overflow: visible;
        }

        .logo-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
        }

        .brand-title {
            font-size: 3.5rem;
            font-weight: 800;
            letter-spacing: -0.05em;
            margin-bottom: 1.5rem;
        }

        .brand-desc {
            max-width: 460px;
            font-size: 1.1rem;
            line-height: 1.6;
            opacity: 0.9;
            font-weight: 500;
        }

        /* --- Login Side --- */
        .login-pane {
            flex: 0.9;
            background: white;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 6rem;
            position: relative;
        }

        .login-content {
            max-width: 420px;
            width: 100%;
            margin: 0 auto;
        }

        .welcome-head {
            font-size: 2.25rem;
            font-weight: 800;
            color: var(--text-main);
            letter-spacing: -0.03em;
            margin-bottom: 0.5rem;
        }

        .welcome-sub {
            color: var(--text-muted);
            margin-bottom: 3rem;
        }

        .form-label {
            font-size: 0.875rem;
            font-weight: 700;
            color: var(--text-main);
            margin-bottom: 0.5rem;
        }

        .form-control {
            background: var(--input-bg);
            border: 1px solid #e2e8f0;
            padding: 1rem 1.25rem;
            border-radius: 0.75rem;
            font-weight: 500;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            background: white;
            border-color: #cbd5e1;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            outline: none;
        }

        .options-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 1.5rem;
            font-size: 0.875rem;
        }

        .forgot-link {
            color: var(--accent);
            text-decoration: none;
            font-weight: 700;
        }

        .btn-signin {
            background: #0f172a;
            color: white;
            border: none;
            width: 100%;
            padding: 1.1rem;
            border-radius: 0.75rem;
            font-weight: 700;
            margin-top: 2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.2s ease;
        }

        .btn-signin:hover {
            background: #1e293b;
            transform: translateY(-1px);
        }

        .footer-note {
            position: absolute;
            bottom: 3rem;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 0.875rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .alert-auth {
            background: #fef2f2;
            border: 1px solid #fee2e2;
            color: #991b1b;
            padding: 1rem;
            border-radius: 0.75rem;
            margin-bottom: 2rem;
            font-size: 0.875rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        @@media (max-width: 992px) {
            .branding-pane { display: none; }
            .login-pane { flex: 1; padding: 2rem; }
        }
    </style>
</head>
<body>
    <div class="split-container">
        <!-- Branding Side -->
        <div class="branding-pane">
            <div class="logo-box">
                <img src="~/TicketGuard.png" asp-append-version="true" alt="TicketGuard logo" class="logo-img" />
            </div>
            <h1 class="brand-title">TicketGuard</h1>
            <p class="brand-desc">
                When payment succeeds but confirmation fails, customers are left with nothing to show for it. 
                TicketGuard for BusOnlineTicket finds those bookings automatically, gives your team the context to act, and keeps a full record of every fix. 
                No raw SQL. No spreadsheets. No guessing.
            </p>
        </div>

        <!-- Login Side -->
        <div class="login-pane">
            <div class="login-content">
                <h2 class="welcome-head">Welcome back</h2>
                <p class="welcome-sub">Enter your credentials to access the BusOnlineTicket command center.</p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert-auth">
                        <i data-lucide="alert-circle" size="18"></i>
                        @ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    <div class="mb-4">
                        <label class="form-label">Email Address</label>
                        <input type="email" name="Email" class="form-control" placeholder="name@company.com" required autofocus>
                    </div>
                    
                    <div class="mb-2">
                        <label class="form-label">Password</label>
                        <input type="password" name="Password" class="form-control" placeholder="••••••••" required>
                    </div>

                    <div class="options-row">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="rememberMe">
                            <label class="form-check-label text-muted" for="rememberMe">Remember me</label>
                        </div>
                        <!-- <%-- <a href="#" class="forgot-link">Forgot Password?</a> --%> -->
                    </div>

                    <button type="submit" class="btn-signin">
                        Sign In <i data-lucide="arrow-right" size="18"></i>
                    </button>
                </form>
            </div>

            <div class="footer-note">
                &copy; @DateTime.Now.Year TicketGuard for BusOnlineTicket. All rights reserved.
            </div>
        </div>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>
